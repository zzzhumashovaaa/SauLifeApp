<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
        xmlns:android="http://schemas.android.com/apk/res/android"
        xmlns:app="http://schemas.android.com/apk/res-auto"
        android:layout_width="210dp"
        android:layout_height="200dp"
        android:layout_marginEnd="14dp"
        app:cardCornerRadius="26dp"
        app:cardElevation="4dp"
        app:cardBackgroundColor="@color/white">

    <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:padding="18dp">

        <FrameLayout
                android:layout_width="46dp"
                android:layout_height="46dp"
                android:background="@drawable/bg_medicine_icon">

            <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_medicine"
                    app:tint="@color/treatment_text_primary" />
        </FrameLayout>

        <TextView
                android:id="@+id/textMedicineName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:maxLines="1"
                android:ellipsize="end"
                android:text="Paracetamol"
                android:textColor="@color/treatment_text_primary"
                android:textSize="17sp"
                android:textStyle="bold" />

        <TextView
                android:id="@+id/textDosage"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:maxLines="1"
                android:ellipsize="end"
                android:text="500 mg"
                android:textColor="@color/treatment_text_secondary"
                android:textSize="13sp" />

        <TextView
                android:id="@+id/textTime"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:text="Келесі: 21:00"
                android:textColor="@color/treatment_text_primary"
                android:textSize="15sp"
                android:textStyle="bold" />

        <TextView
                android:id="@+id/textQuantity"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Қалды: 12"
                android:textColor="@color/treatment_text_secondary"
                android:textSize="13sp" />

        <TextView
                android:id="@+id/textStatus"
                android:layout_width="wrap_content"
                android:layout_height="30dp"
                android:layout_marginTop="12dp"
                android:gravity="center"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:background="@drawable/bg_button"
                android:text="Белсенді"
                android:textColor="@color/white"
                android:textSize="12sp"
                android:textStyle="bold" />

    </LinearLayout>

</androidx.cardview.widget.CardView>