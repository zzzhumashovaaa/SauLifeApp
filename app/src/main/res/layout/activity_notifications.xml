<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
        xmlns:android="http://schemas.android.com/apk/res/android"
        xmlns:app="http://schemas.android.com/apk/res-auto"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#F7F9FC"
        android:fillViewport="true">

    <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="36dp"
            android:paddingBottom="32dp">

        <!-- TOP BAR -->
        <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

            <androidx.cardview.widget.CardView
                    android:layout_width="54dp"
                    android:layout_height="54dp"
                    app:cardCornerRadius="18dp"
                    app:cardBackgroundColor="@android:color/transparent"
                    app:cardElevation="0dp">

                <ImageButton
                        android:id="@+id/btnBack"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:src="@drawable/ic_back"
                        app:tint="#000000"
                        android:background="@android:color/transparent" />

            </androidx.cardview.widget.CardView>

            <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="16dp"
                    android:text="Хабарламалар"
                    android:textColor="#0F172A"
                    android:textSize="24dp"
                    android:fontFamily="sans-serif-black" />

        </LinearLayout>

        <!-- FILTER CHIPS -->
        <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="26dp"
                android:scrollbars="none">

            <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                <com.google.android.material.chip.Chip
                        android:id="@+id/chipAll"
                        android:layout_width="wrap_content"
                        android:layout_height="44dp"
                        android:text="▦  Барлығы"
                        android:checked="true"
                        android:checkable="true"
                        app:checkedIconVisible="false"
                        app:chipBackgroundColor="#DDF5F2"
                        android:textColor="#0F766E" />

                <com.google.android.material.chip.Chip
                        android:id="@+id/chipPills"
                        android:layout_width="wrap_content"
                        android:layout_height="44dp"
                        android:layout_marginStart="8dp"
                        android:text="💊 Дәрілер"
                        android:checkable="true"
                        app:checkedIconVisible="false" />

                <com.google.android.material.chip.Chip
                        android:id="@+id/chipReminders"
                        android:layout_width="wrap_content"
                        android:layout_height="44dp"
                        android:layout_marginStart="8dp"
                        android:text="⏰ Қабылдау"
                        android:checkable="true"
                        app:checkedIconVisible="false" />

                <com.google.android.material.chip.Chip
                        android:id="@+id/chipHealth"
                        android:layout_width="wrap_content"
                        android:layout_height="44dp"
                        android:layout_marginStart="8dp"
                        android:text="♡ Денсаулық"
                        android:checkable="true"
                        app:checkedIconVisible="false" />

                <com.google.android.material.chip.Chip
                        android:id="@+id/chipImportant"
                        android:layout_width="wrap_content"
                        android:layout_height="44dp"
                        android:layout_marginStart="8dp"
                        android:text="⚠ Маңызды"
                        android:checkable="true"
                        app:checkedIconVisible="false" />

            </LinearLayout>

        </HorizontalScrollView>

        <!-- ТАБЛЕТКАЛАР -->
        <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="34dp"
                android:text="💊  Дәрілер"
                android:textColor="#0F172A"
                android:textSize="20sp"
                android:fontFamily="sans-serif-black" />

        <include
                android:id="@+id/layoutExpiry"
                layout="@layout/item_notification_expiry" />

        <include
                android:id="@+id/layoutExpired"
                layout="@layout/item_notification_expired" />

        <include
                android:id="@+id/layoutStock"
                layout="@layout/item_notification_stock" />

        <!-- ҚАБЫЛДАУ -->
        <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="30dp"
                android:text="⏰  Қабылдау еске салғыштары"
                android:textColor="#0F172A"
                android:textSize="20sp"
                android:fontFamily="sans-serif-black" />

        <include
                android:id="@+id/layoutTakeMedicine"
                layout="@layout/item_notification_take_medicine" />

        <include
                android:id="@+id/layoutMissed"
                layout="@layout/item_notification_missed" />

        <!-- ДЕНСАУЛЫҚ -->
        <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="30dp"
                android:text="♡  Денсаулық / AI талдау"
                android:textColor="#0F172A"
                android:textSize="20sp"
                android:fontFamily="sans-serif-black" />

        <include
                android:id="@+id/layoutAiWarning"
                layout="@layout/item_notification_ai_warning" />

        <include
                android:id="@+id/layoutHealthCheck"
                layout="@layout/item_notification_health_check" />

        <!-- МАҢЫЗДЫ -->
        <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="30dp"
                android:text="⚠  Шұғыл / Маңызды"
                android:textColor="#0F172A"
                android:textSize="20sp"
                android:fontFamily="sans-serif-black" />

        <include
                android:id="@+id/layoutCritical"
                layout="@layout/item_notification_critical" />

        <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="30dp"
                android:text="💬  AI чат / Көмекші"
                android:textColor="#0F172A"
                android:textSize="20sp"
                android:fontFamily="sans-serif-black" />

        <include
                android:id="@+id/layoutAiChat"
                layout="@layout/item_notification_ai_chat" />

    </LinearLayout>

</androidx.core.widget.NestedScrollView>