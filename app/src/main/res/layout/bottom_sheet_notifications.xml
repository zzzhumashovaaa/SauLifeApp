<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_bottom_sheet"
    android:paddingBottom="32dp">

    <!-- Handle -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="14dp"
        android:layout_marginBottom="20dp"
        android:background="@drawable/bg_sheet_handle"/>

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="22dp"
        android:paddingEnd="22dp"
        android:layout_marginBottom="6dp">

        <com.google.android.material.card.MaterialCardView
            android:layout_width="44dp"
            android:layout_height="44dp"
            app:cardCornerRadius="13dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="#EEF1FE"
            app:strokeWidth="0dp"
            android:layout_marginEnd="14dp">
            <TextView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:text="🔔"
                android:textSize="20sp"/>
        </com.google.android.material.card.MaterialCardView>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Хабарламалар"
                android:textColor="#0D1B2A"
                android:textSize="18sp"
                android:textStyle="bold"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Рұқсаттар мен баптаулар"
                android:textColor="#9AAAB8"
                android:textSize="12sp"
                android:layout_marginTop="2dp"/>
        </LinearLayout>
    </LinearLayout>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#F0F2F5"
        android:layout_marginBottom="4dp"/>

    <!-- Push notifications row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="22dp"
        android:paddingEnd="22dp">

        <com.google.android.material.card.MaterialCardView
            android:layout_width="38dp"
            android:layout_height="38dp"
            app:cardCornerRadius="10dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="#E6F7F6"
            app:strokeWidth="0dp"
            android:layout_marginEnd="14dp">
            <TextView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:text="📳"
                android:textSize="16sp"/>
        </com.google.android.material.card.MaterialCardView>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Push хабарламалар"
                android:textColor="#0D1B2A"
                android:textSize="14sp"
                android:textStyle="bold"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Жүйелік хабарландыруларға рұқсат"
                android:textColor="#9AAAB8"
                android:textSize="12sp"
                android:layout_marginTop="2dp"/>
        </LinearLayout>

        <Switch
            android:id="@+id/switchPushNotif"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:thumbTint="#0F9B8E"
            android:trackTint="#B2E8E4"/>
    </LinearLayout>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#F0F2F5"
        android:layout_marginStart="74dp"/>

    <!-- Med reminder row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="22dp"
        android:paddingEnd="22dp">

        <com.google.android.material.card.MaterialCardView
            android:layout_width="38dp"
            android:layout_height="38dp"
            app:cardCornerRadius="10dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="#FFF8ED"
            app:strokeWidth="0dp"
            android:layout_marginEnd="14dp">
            <TextView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:text="💊"
                android:textSize="16sp"/>
        </com.google.android.material.card.MaterialCardView>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Дәрі еске салу"
                android:textColor="#0D1B2A"
                android:textSize="14sp"
                android:textStyle="bold"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Дәрі ішу уақытын еске салу"
                android:textColor="#9AAAB8"
                android:textSize="12sp"
                android:layout_marginTop="2dp"/>
        </LinearLayout>

        <Switch
            android:id="@+id/switchMedReminder"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:thumbTint="#0F9B8E"
            android:trackTint="#B2E8E4"/>
    </LinearLayout>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#F0F2F5"
        android:layout_marginStart="74dp"/>

    <!-- Appointments row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="22dp"
        android:paddingEnd="22dp">

        <com.google.android.material.card.MaterialCardView
            android:layout_width="38dp"
            android:layout_height="38dp"
            app:cardCornerRadius="10dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="#EEF1FE"
            app:strokeWidth="0dp"
            android:layout_marginEnd="14dp">
            <TextView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:text="🗓️"
                android:textSize="16sp"/>
        </com.google.android.material.card.MaterialCardView>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Кездесу еске салулары"
                android:textColor="#0D1B2A"
                android:textSize="14sp"
                android:textStyle="bold"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Дәрігер визиттерін еске салу"
                android:textColor="#9AAAB8"
                android:textSize="12sp"
                android:layout_marginTop="2dp"/>
        </LinearLayout>

        <Switch
            android:id="@+id/switchAppointments"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:thumbTint="#0F9B8E"
            android:trackTint="#B2E8E4"/>
    </LinearLayout>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#F0F2F5"
        android:layout_marginStart="74dp"/>

    <!-- Health news row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="22dp"
        android:paddingEnd="22dp">

        <com.google.android.material.card.MaterialCardView
            android:layout_width="38dp"
            android:layout_height="38dp"
            app:cardCornerRadius="10dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="#EAF3DE"
            app:strokeWidth="0dp"
            android:layout_marginEnd="14dp">
            <TextView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:text="📰"
                android:textSize="16sp"/>
        </com.google.android.material.card.MaterialCardView>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Денсаулық жаңалықтары"
                android:textColor="#0D1B2A"
                android:textSize="14sp"
                android:textStyle="bold"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Пайдалы кеңестер мен мақалалар"
                android:textColor="#9AAAB8"
                android:textSize="12sp"
                android:layout_marginTop="2dp"/>
        </LinearLayout>

        <Switch
            android:id="@+id/switchHealthNews"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:thumbTint="#0F9B8E"
            android:trackTint="#B2E8E4"/>
    </LinearLayout>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#F0F2F5"
        android:layout_marginBottom="20dp"/>

    <!-- Save button -->
    <Button
        android:id="@+id/btnSaveNotif"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_marginStart="22dp"
        android:layout_marginEnd="22dp"
        android:text="Сақтау"
        android:textAllCaps="false"
        android:textColor="#FFFFFF"
        android:textSize="15sp"
        android:textStyle="bold"
        android:backgroundTint="#0F9B8E"
        app:cornerRadius="16dp"/>

</LinearLayout>
