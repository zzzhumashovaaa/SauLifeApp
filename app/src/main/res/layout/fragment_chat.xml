<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
        xmlns:app="http://schemas.android.com/apk/res-auto"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#F0F4F8"
        android:orientation="vertical">

    <!-- Header -->
    <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#FFFFFF"
            android:elevation="2dp"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="20dp"
            android:paddingBottom="14dp">

        <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

            <!-- AI Avatar -->
            <com.google.android.material.card.MaterialCardView
                    android:layout_width="46dp"
                    android:layout_height="46dp"
                    app:cardCornerRadius="14dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="#E6F7F6"
                    app:strokeWidth="0dp"
                    android:layout_marginEnd="14dp">

                <TextView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:text="🩺"
                        android:textSize="22sp" />
            </com.google.android.material.card.MaterialCardView>

            <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="MedAI Ассистент"
                        android:textColor="#0D1B2A"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:layout_marginTop="2dp">

                    <View
                            android:layout_width="7dp"
                            android:layout_height="7dp"
                            android:background="@drawable/circle_green_dot"
                            android:layout_marginEnd="6dp" />

                    <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Онлайн"
                            android:textColor="#0F9B8E"
                            android:textSize="12sp"
                            android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>

            <!-- History button -->
            <com.google.android.material.card.MaterialCardView
                    android:id="@+id/btnChatHistory"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="#F0F4F8"
                    app:strokeWidth="0dp">

                <TextView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:text="🕘"
                        android:textSize="18sp" />
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>

        <!-- Disclaimer chip -->
        <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="10dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#FFF8ED"
                app:strokeColor="#F6D89A"
                app:strokeWidth="1dp"
                android:layout_marginTop="12dp">

            <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="10dp"
                    android:text="⚠️  Ассистент кеңес береді, бірақ дәрігерді алмастырмайды"
                    android:textColor="#9A6A00"
                    android:textSize="12sp" />
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>

    <!-- Quick action chips -->
    <HorizontalScrollView
            android:id="@+id/layoutQuickActions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none"
            android:paddingTop="12dp"
            android:paddingBottom="4dp"
            android:background="#F0F4F8">

        <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingStart="16dp"
                android:paddingEnd="16dp">

            <com.google.android.material.chip.Chip
                    android:id="@+id/chipPregnancy"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:text="🤰 Жүктілер үшін"
                    android:textSize="13sp"
                    android:textColor="#0D1B2A"
                    app:chipBackgroundColor="#FFFFFF"
                    app:chipStrokeColor="#D8E0EB"
                    app:chipStrokeWidth="1dp"
                    app:chipCornerRadius="18dp"
                    app:chipIconVisible="false"
                    app:checkedIconVisible="false"
                    style="@style/Widget.MaterialComponents.Chip.Action" />

            <com.google.android.material.chip.Chip
                    android:id="@+id/chipAnalog"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:layout_marginStart="8dp"
                    android:text="🔄 Аналог таңдау"
                    android:textSize="13sp"
                    android:textColor="#0D1B2A"
                    app:chipBackgroundColor="#FFFFFF"
                    app:chipStrokeColor="#D8E0EB"
                    app:chipStrokeWidth="1dp"
                    app:chipCornerRadius="18dp"
                    app:chipIconVisible="false"
                    app:checkedIconVisible="false"
                    style="@style/Widget.MaterialComponents.Chip.Action" />

            <com.google.android.material.chip.Chip
                    android:id="@+id/chipHowToTake"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:layout_marginStart="8dp"
                    android:text="💊 Қалай қабылдау?"
                    android:textSize="13sp"
                    android:textColor="#0D1B2A"
                    app:chipBackgroundColor="#FFFFFF"
                    app:chipStrokeColor="#D8E0EB"
                    app:chipStrokeWidth="1dp"
                    app:chipCornerRadius="18dp"
                    app:chipIconVisible="false"
                    app:checkedIconVisible="false"
                    style="@style/Widget.MaterialComponents.Chip.Action" />

            <com.google.android.material.chip.Chip
                    android:id="@+id/chipFindDrug"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:layout_marginStart="8dp"
                    android:text="🔍 Препарат іздеу"
                    android:textSize="13sp"
                    android:textColor="#0D1B2A"
                    app:chipBackgroundColor="#FFFFFF"
                    app:chipStrokeColor="#D8E0EB"
                    app:chipStrokeWidth="1dp"
                    app:chipCornerRadius="18dp"
                    app:chipIconVisible="false"
                    app:checkedIconVisible="false"
                    style="@style/Widget.MaterialComponents.Chip.Action" />

            <com.google.android.material.chip.Chip
                    android:id="@+id/chipSideEffects"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:layout_marginStart="8dp"
                    android:text="⚡ Жанама әсерлер"
                    android:textSize="13sp"
                    android:textColor="#0D1B2A"
                    app:chipBackgroundColor="#FFFFFF"
                    app:chipStrokeColor="#D8E0EB"
                    app:chipStrokeWidth="1dp"
                    app:chipCornerRadius="18dp"
                    app:chipIconVisible="false"
                    app:checkedIconVisible="false"
                    style="@style/Widget.MaterialComponents.Chip.Action" />
        </LinearLayout>
    </HorizontalScrollView>

    <!-- Chat messages -->
    <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerChat"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:clipToPadding="false"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="12dp"
            android:paddingBottom="12dp" />

    <!-- Input bar -->
    <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#FFFFFF"
            android:elevation="8dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:paddingTop="10dp"
            android:paddingBottom="10dp">

        <com.google.android.material.textfield.TextInputLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="Сұрағыңызды жазыңыз..."
                app:boxBackgroundColor="#F0F4F8"
                app:boxBackgroundMode="filled"
                app:boxCornerRadiusBottomEnd="20dp"
                app:boxCornerRadiusBottomStart="20dp"
                app:boxCornerRadiusTopEnd="20dp"
                app:boxCornerRadiusTopStart="20dp"
                app:hintTextColor="#9AAAB8"
                app:boxStrokeWidth="0dp"
                app:boxStrokeWidthFocused="0dp">

            <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/editMessage"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:maxLines="4"
                    android:textColor="#0D1B2A"
                    android:textSize="15sp" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Send button -->
        <com.google.android.material.card.MaterialCardView
                android:id="@+id/btnSend"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_marginStart="10dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#0F9B8E"
                app:strokeWidth="0dp">

            <TextView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:text="↑"
                    android:textColor="#FFFFFF"
                    android:textSize="22sp"
                    android:textStyle="bold" />
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>

</LinearLayout>