<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_bottom_sheet">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="36dp">

        <!-- Handle -->
        <View
            android:layout_width="40dp"
            android:layout_height="4dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="14dp"
            android:layout_marginBottom="22dp"
            android:background="@drawable/bg_sheet_handle"/>

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="22dp"
            android:paddingEnd="22dp"
            android:layout_marginBottom="24dp">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="44dp"
                android:layout_height="44dp"
                app:cardCornerRadius="13dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#E6F7F6"
                app:strokeWidth="0dp"
                android:layout_marginEnd="14dp">
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:text="⚙️"
                    android:textSize="20sp"/>
            </com.google.android.material.card.MaterialCardView>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Баптаулар"
                    android:textColor="#0D1B2A"
                    android:textSize="20sp"
                    android:textStyle="bold"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Тіл, тақырып, хабарламалар"
                    android:textColor="#9AAAB8"
                    android:textSize="12sp"
                    android:layout_marginTop="2dp"/>
            </LinearLayout>
        </LinearLayout>

        <!-- ════ ТІЛ БӨЛІМІ ════ -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="ТІЛ"
            android:textColor="#9AAAB8"
            android:textSize="11sp"
            android:textStyle="bold"
            android:letterSpacing="0.08"
            android:paddingStart="22dp"
            android:paddingEnd="22dp"
            android:layout_marginBottom="10dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="22dp"
            android:paddingEnd="22dp"
            android:layout_marginBottom="26dp"
            android:weightSum="3">

            <!-- Қазақша -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardLangKk"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#FFFFFF"
                app:strokeColor="#E8ECF2"
                app:strokeWidth="1dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:paddingTop="14dp"
                    android:paddingBottom="14dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🇰🇿"
                        android:textSize="28sp"
                        android:layout_marginBottom="6dp"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Қазақша"
                        android:textColor="#0D1B2A"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:gravity="center"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Русский -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardLangRu"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#FFFFFF"
                app:strokeColor="#E8ECF2"
                app:strokeWidth="1dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:paddingTop="14dp"
                    android:paddingBottom="14dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🇷🇺"
                        android:textSize="28sp"
                        android:layout_marginBottom="6dp"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Русский"
                        android:textColor="#0D1B2A"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:gravity="center"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- English -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardLangEn"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#FFFFFF"
                app:strokeColor="#E8ECF2"
                app:strokeWidth="1dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:paddingTop="14dp"
                    android:paddingBottom="14dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🇬🇧"
                        android:textSize="28sp"
                        android:layout_marginBottom="6dp"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="English"
                        android:textColor="#0D1B2A"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:gravity="center"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>

        <!-- ════ ТАҚЫРЫП БӨЛІМІ ════ -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="ТАҚЫРЫП"
            android:textColor="#9AAAB8"
            android:textSize="11sp"
            android:textStyle="bold"
            android:letterSpacing="0.08"
            android:paddingStart="22dp"
            android:paddingEnd="22dp"
            android:layout_marginBottom="10dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="22dp"
            android:paddingEnd="22dp"
            android:layout_marginBottom="26dp"
            android:weightSum="3">

            <!-- Авто / Жүйе -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardThemeSystem"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#FFFFFF"
                app:strokeColor="#E8ECF2"
                app:strokeWidth="1dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:paddingTop="14dp"
                    android:paddingBottom="14dp">

                    <!-- Half-half preview using layer -->
                    <FrameLayout
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:layout_marginBottom="8dp">
                        <View
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:background="@drawable/theme_preview_auto"/>
                    </FrameLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Авто"
                        android:textColor="#0D1B2A"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:gravity="center"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Жүйе"
                        android:textColor="#9AAAB8"
                        android:textSize="9sp"
                        android:gravity="center"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Жарық -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardThemeLight"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#FFFFFF"
                app:strokeColor="#E8ECF2"
                app:strokeWidth="1dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:paddingTop="14dp"
                    android:paddingBottom="14dp">

                    <FrameLayout
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:layout_marginBottom="8dp">
                        <View
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:background="@drawable/theme_preview_light"/>
                    </FrameLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Жарық"
                        android:textColor="#0D1B2A"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:gravity="center"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Light"
                        android:textColor="#9AAAB8"
                        android:textSize="9sp"
                        android:gravity="center"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Қараңғы -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardThemeDark"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#FFFFFF"
                app:strokeColor="#E8ECF2"
                app:strokeWidth="1dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:paddingTop="14dp"
                    android:paddingBottom="14dp">

                    <FrameLayout
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:layout_marginBottom="8dp">
                        <View
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:background="@drawable/theme_preview_dark"/>
                    </FrameLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Қараңғы"
                        android:textColor="#0D1B2A"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:gravity="center"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Dark"
                        android:textColor="#9AAAB8"
                        android:textSize="9sp"
                        android:gravity="center"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>

        <!-- ════ ХАБАРЛАМАЛАР жолы ════ -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="ХАБАРЛАМАЛАР"
            android:textColor="#9AAAB8"
            android:textSize="11sp"
            android:textStyle="bold"
            android:letterSpacing="0.08"
            android:paddingStart="22dp"
            android:paddingEnd="22dp"
            android:layout_marginBottom="10dp"/>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardGoNotifications"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="22dp"
            android:layout_marginEnd="22dp"
            android:layout_marginBottom="24dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="#FFFFFF"
            app:strokeColor="#E8ECF2"
            app:strokeWidth="1dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="16dp">
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="38dp"
                    android:layout_height="38dp"
                    app:cardCornerRadius="10dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="#EEF1FE"
                    app:strokeWidth="0dp"
                    android:layout_marginEnd="14dp">
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:text="🔔"
                        android:textSize="16sp"/>
                </com.google.android.material.card.MaterialCardView>
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Хабарламалар баптаулары"
                        android:textColor="#0D1B2A"
                        android:textSize="14sp"
                        android:textStyle="bold"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Рұқсаттар, дәрі еске салулары"
                        android:textColor="#9AAAB8"
                        android:textSize="11sp"
                        android:layout_marginTop="2dp"/>
                </LinearLayout>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="›"
                    android:textColor="#9AAAB8"
                    android:textSize="22sp"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#F0F2F5"
            android:layout_marginStart="22dp"
            android:layout_marginEnd="22dp"
            android:layout_marginBottom="16dp"/>

        <!-- Version -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="SauLife v1.0.0"
            android:textColor="#C5CDD8"
            android:textSize="11sp"
            android:gravity="center"/>

    </LinearLayout>
</ScrollView>
