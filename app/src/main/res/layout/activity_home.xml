<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
        xmlns:android="http://schemas.android.com/apk/res/android"
        xmlns:app="http://schemas.android.com/apk/res-auto"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#FFFFFF">

    <ScrollView
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:fillViewport="false"
            app:layout_constraintBottom_toTopOf="@id/bottomBar"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="24dp"
                android:paddingTop="48dp"
                android:paddingEnd="24dp"
                android:paddingBottom="32dp">

            <LinearLayout
                    android:id="@+id/layoutSearch"
                    android:layout_width="match_parent"
                    android:layout_height="58dp"
                    android:background="@drawable/bg_search"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp">

                <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Search Medicine &amp; Health Products"
                        android:textColor="#8E8E99"
                        android:textSize="16sp" />

                <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@android:drawable/ic_menu_search"
                        app:tint="#8E8E99" />

            </LinearLayout>

            <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="162dp"
                    android:layout_marginTop="24dp"
                    app:cardBackgroundColor="#D9CEFF"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="0dp">

                <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:padding="20dp">

                    <TextView
                            android:id="@+id/textNewsLabel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="HEALTH NEWS"
                            android:textColor="#171725"
                            android:textSize="18sp"
                            android:textStyle="bold" />

                    <TextView
                            android:id="@+id/textNewsTitle"
                            android:layout_width="230dp"
                            android:layout_height="wrap_content"
                            android:layout_below="@id/textNewsLabel"
                            android:layout_marginTop="8dp"
                            android:maxLines="1"
                            android:ellipsize="end"
                            android:text="Medical news in Kazakhstan"
                            android:textColor="#171725"
                            android:textSize="15sp"
                            android:textStyle="bold" />

                    <TextView
                            android:id="@+id/textNewsDesc"
                            android:layout_width="230dp"
                            android:layout_height="wrap_content"
                            android:layout_below="@id/textNewsTitle"
                            android:layout_marginTop="4dp"
                            android:ellipsize="end"
                            android:maxLines="2"
                            android:text="Latest health updates and useful medical articles."
                            android:textColor="#2D2D2D"
                            android:textSize="14sp" />

                    <TextView
                            android:layout_width="70dp"
                            android:layout_height="70dp"
                            android:layout_alignParentEnd="true"
                            android:layout_marginTop="8dp"
                            android:gravity="center"
                            android:text="🩺"
                            android:textSize="48sp" />

                    <Button
                            android:id="@+id/btnReadNews"
                            android:layout_width="124dp"
                            android:layout_height="46dp"
                            android:layout_alignParentEnd="true"
                            android:layout_alignParentBottom="true"
                            android:background="@drawable/bg_button"
                            android:text="Read"
                            android:textAllCaps="false"
                            android:textColor="#FFFFFF"
                            android:textStyle="bold" />

                </RelativeLayout>

            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="172dp"
                    android:layout_marginTop="22dp"
                    app:cardBackgroundColor="#C9F5C8"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="0dp">

                <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:padding="20dp">

                    <TextView
                            android:id="@+id/textDiscount"
                            android:layout_width="160dp"
                            android:layout_height="wrap_content"
                            android:text="UPTO\n80%"
                            android:textColor="#121221"
                            android:textSize="38sp"
                            android:textStyle="bold" />

                    <TextView
                            android:id="@+id/textDiscountDesc"
                            android:layout_width="190dp"
                            android:layout_height="wrap_content"
                            android:layout_below="@id/textDiscount"
                            android:layout_marginTop="0dp"
                            android:text="On Health Products"
                            android:textColor="#121221"
                            android:textSize="15sp"
                            android:textStyle="bold" />

                    <Button
                            android:id="@+id/btnShopNow"
                            android:layout_width="120dp"
                            android:layout_height="44dp"
                            android:layout_alignParentStart="true"
                            android:layout_alignParentBottom="true"
                            android:backgroundTint="#12B76A"
                            android:text="Shop Now"
                            android:textAllCaps="false"
                            android:textColor="#FFFFFF"
                            android:textStyle="bold" />

                    <TextView
                            android:layout_width="120dp"
                            android:layout_height="120dp"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"
                            android:gravity="center"
                            android:text="💊"
                            android:textSize="74sp" />

                </RelativeLayout>

            </androidx.cardview.widget.CardView>

            <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="28dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Popular Product"
                        android:textColor="#242424"
                        android:textSize="22sp"
                        android:textStyle="bold" />

                <TextView
                        android:id="@+id/textSeeAllPopular"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="See all"
                        android:textColor="#6147F5"
                        android:textSize="15sp" />

            </LinearLayout>

            <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/recyclerPopular"
                    android:layout_width="match_parent"
                    android:layout_height="220dp"
                    android:layout_marginTop="16dp"
                    android:clipToPadding="false"
                    android:overScrollMode="never" />

            <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="26dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Product on Sale"
                        android:textColor="#242424"
                        android:textSize="22sp"
                        android:textStyle="bold" />

                <TextView
                        android:id="@+id/textSeeAllSale"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="See all"
                        android:textColor="#6147F5"
                        android:textSize="15sp" />

            </LinearLayout>

            <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/recyclerSale"
                    android:layout_width="match_parent"
                    android:layout_height="220dp"
                    android:layout_marginTop="16dp"
                    android:clipToPadding="false"
                    android:overScrollMode="never" />

        </LinearLayout>

    </ScrollView>

    <LinearLayout
            android:id="@+id/bottomBar"
            android:layout_width="0dp"
            android:layout_height="92dp"
            android:background="#FFFFFF"
            android:gravity="center"
            android:orientation="horizontal"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent">

        <LinearLayout
                android:id="@+id/navHome"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">

            <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⌂"
                    android:textColor="#6147F5"
                    android:textSize="28sp" />

            <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Home"
                    android:textColor="#6147F5"
                    android:textSize="13sp" />

        </LinearLayout>

        <LinearLayout
                android:id="@+id/navPrescription"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">

            <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⚕"
                    android:textColor="#9EB5D4"
                    android:textSize="28sp" />

        </LinearLayout>

        <Space
                android:layout_width="78dp"
                android:layout_height="match_parent" />

        <LinearLayout
                android:id="@+id/navDelivery"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">

            <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="▣"
                    android:textColor="#9EB5D4"
                    android:textSize="26sp" />

        </LinearLayout>

        <LinearLayout
                android:id="@+id/navMore"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">

            <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="☰"
                    android:textColor="#9EB5D4"
                    android:textSize="26sp" />

        </LinearLayout>

    </LinearLayout>

    <ImageButton
            android:id="@+id/fabScan"
            android:layout_width="78dp"
            android:layout_height="78dp"
            android:background="@drawable/bg_circle_primary"
            android:elevation="12dp"
            android:src="@android:drawable/ic_menu_camera"
            app:tint="#FFFFFF"
            app:layout_constraintBottom_toBottomOf="@id/bottomBar"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="@id/bottomBar" />

</androidx.constraintlayout.widget.ConstraintLayout>