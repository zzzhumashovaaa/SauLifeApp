<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
        xmlns:app="http://schemas.android.com/apk/res-auto"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#F5F7FB"
        android:fillViewport="false"
        android:overScrollMode="never">

    <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingTop="35dp"
            android:paddingEnd="20dp"
            android:paddingBottom="32dp">

        <!-- Greeting -->
        <!-- Greeting -->
        <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

            <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                <TextView
                        android:id="@+id/textGreeting"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Қайырлы кеш, Айжан"
                        android:textColor="#0F172A"
                        android:textSize="24sp"
                        android:textStyle="bold" />

                <TextView
                        android:id="@+id/textGreetingSubtitle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="Бүгін өзіңізді қалай сезініп тұрсыз?"
                        android:textColor="#64748B"
                        android:textSize="12sp" />
            </LinearLayout>

            <ImageView
                android:id="@+id/btnNotifications"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:padding="8dp"
                android:clickable="true"
                android:focusable="true"
                android:src="@drawable/ic_notification"
                android:contentDescription="Notifications"
                app:tint="#0F172A" />

        </LinearLayout>

        <!-- Search -->


        <LinearLayout
                android:id="@+id/layoutSearch"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="20dp"
                android:background="@drawable/bg_search"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="18dp"
                android:paddingEnd="18dp">

            <ImageButton
                    android:id="@+id/btnSearchIcon"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:background="@android:color/transparent"
                    android:padding="6dp"
                    android:src="@android:drawable/ic_menu_search"
                    android:contentDescription="Search"
                    app:tint="#94A3B8"/>

            <EditText
                    android:id="@+id/editSearch"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:layout_weight="1"
                    android:background="@android:color/transparent"
                    android:hint="Дәрі немесе дәріхана іздеу"
                    android:textColor="#111827"
                    android:textColorHint="#94A3B8"
                    android:textSize="14sp"
                    android:singleLine="true"
                    android:inputType="text"
                    android:imeOptions="actionSearch"/>

        </LinearLayout>

        <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerMedicineSearchResults"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:visibility="gone"
                android:nestedScrollingEnabled="false" />

        <!-- Health Summary -->
        <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="22dp"
                app:cardBackgroundColor="#FFFFFF"
                app:cardCornerRadius="30dp"
                app:cardElevation="1dp">

            <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="22dp">

                <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Денсаулық қорытындысы"
                        android:textColor="#0F172A"
                        android:textSize="18dp"
                        android:textStyle="bold" />

                <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="5dp"
                        android:text="Қазіргі емдеу жоспарыңыз"
                        android:textColor="#64748B"
                        android:textSize="12dp" />

                <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="22dp"
                        android:orientation="horizontal">

                    <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:background="@drawable/bg_button"
                            android:orientation="vertical"
                            android:padding="16dp">

                        <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Дәрілер"
                                android:textColor="#FFFFFF"
                                android:textSize="12dp" />

                        <TextView
                                android:id="@+id/textActiveMedicines"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:text="3"
                                android:textColor="#FFFFFF"
                                android:textSize="24dp"
                                android:textStyle="bold" />
                    </LinearLayout>

                    <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"
                            android:layout_weight="1.45"
                            android:background="@drawable/bg_button"
                            android:orientation="vertical"
                            android:padding="16dp">

                        <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Келесі қабылдау"
                                android:textColor="#FFFFFF"
                                android:textSize="12dp" />

                        <TextView
                                android:id="@+id/textNextMedicine"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="7dp"
                                android:text="Парацетамол — 21:00"
                                android:textColor="#FFFFFF"
                                android:textSize="15sp"
                                android:textStyle="bold" />
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:orientation="horizontal">

                    <TextView
                            android:id="@+id/textCourseProgress"
                            android:layout_width="0dp"
                            android:layout_height="44dp"
                            android:layout_weight="1"
                            android:background="@drawable/bg_button"
                            android:gravity="center"
                            android:text="5/10 күн"
                            android:textColor="#FFFFFF"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                    <TextView
                            android:id="@+id/textAdherence"
                            android:layout_width="0dp"
                            android:layout_height="44dp"
                            android:layout_marginStart="12dp"
                            android:layout_weight="1"
                            android:background="@drawable/bg_success_chip"
                            android:gravity="center"
                            android:text="86%"
                            android:textColor="#059669"
                            android:textSize="14sp"
                            android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Quick Actions -->
        <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                android:text="Жылдам әрекеттер"
                android:textColor="#0F172A"
                android:textSize="18dp"
                android:textStyle="bold" />

        <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerQuickActions"
                android:layout_width="match_parent"
                android:layout_height="126dp"
                android:layout_marginTop="14dp"
                android:clipToPadding="false"
                android:overScrollMode="never" />

        <!-- AI Insights -->
        <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="AI денсаулық кеңестері"
                android:textColor="#0F172A"
                android:textSize="18dp"
                android:textStyle="bold" />

        <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerHealthInsights"
                android:layout_width="match_parent"
                android:layout_height="146dp"
                android:layout_marginTop="14dp"
                android:clipToPadding="false"
                android:overScrollMode="never" />

        <!-- SOS -->
        <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="22dp"
                app:cardBackgroundColor="#FFF5F5"
                app:cardCornerRadius="30dp"
                app:cardElevation="0dp">

        </androidx.cardview.widget.CardView>

        <!-- News -->
        <TextView
                android:id="@+id/titleNews"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                android:text="Қазақстандағы денсаулық жаңалықтары"
                android:textColor="#0F172A"
                android:textSize="18dp"
                android:textStyle="bold" />

        <ProgressBar
                android:id="@+id/progressNews"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp" />

        <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerNews"
                android:layout_width="match_parent"
                android:layout_height="150dp"
                android:layout_marginTop="12dp"
                android:clipToPadding="false"
                android:overScrollMode="never" />

        <!-- Pharmacy Compare -->
        <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="172dp"
                android:layout_marginTop="22dp"
                app:cardBackgroundColor="#ECFDF5"
                app:cardCornerRadius="30dp"
                app:cardElevation="0dp">

            <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:padding="22dp">

                <TextView
                        android:id="@+id/textDiscount"
                        android:layout_width="210dp"
                        android:layout_height="wrap_content"
                        android:text="Дәріхана бағаларын салыстыру"
                        android:textColor="#0F172A"
                        android:textSize="18dp"
                        android:textStyle="bold" />

                <TextView
                        android:id="@+id/textDiscountDesc"
                        android:layout_width="210dp"
                        android:layout_height="wrap_content"
                        android:layout_below="@id/textDiscount"
                        android:layout_marginTop="5dp"
                        android:text="Жақын дәріханалардан тиімді баға табыңыз"
                        android:textColor="#475569"
                        android:textSize="12sp" />

                <Button
                        android:id="@+id/btnShopNow"
                        android:layout_width="100dp"
                        android:layout_height="46dp"
                        android:layout_alignParentStart="true"
                        android:layout_alignParentBottom="true"
                        android:backgroundTint="#10B981"
                        android:text="Іздеу"
                        android:textAllCaps="false"
                        android:textColor="#FFFFFF"
                        android:textStyle="bold" />

                <TextView
                        android:layout_width="104dp"
                        android:layout_height="104dp"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:gravity="center"
                        android:text="💊"
                        android:textSize="64sp" />
            </RelativeLayout>
        </androidx.cardview.widget.CardView>

        <!-- Cart -->
        <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="30dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

            <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Себеттегі тауарлар"
                    android:textColor="#0F172A"
                    android:textSize="18dp"
                    android:textStyle="bold" />

            <TextView
                    android:id="@+id/textSeeAllCart"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Барлығы"
                    android:textColor="#11A36A"
                    android:textSize="12dp"
                    android:textStyle="bold" />
        </LinearLayout>

        <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerCart"
                android:layout_width="match_parent"
                android:layout_height="220dp"
                android:layout_marginTop="14dp"
                android:clipToPadding="false"
                android:overScrollMode="never" />


    </LinearLayout>
</ScrollView>