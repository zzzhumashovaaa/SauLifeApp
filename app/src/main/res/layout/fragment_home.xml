<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
        xmlns:app="http://schemas.android.com/apk/res-auto"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#F7F8FC"
        android:fillViewport="false">

    <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingTop="24dp"
            android:paddingEnd="20dp"
            android:paddingBottom="28dp">

        <TextView
                android:id="@+id/textGreeting"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Қайырлы кеш, Айжан"
                android:textColor="#111827"
                android:textSize="25sp"
                android:textStyle="bold" />

        <TextView
                android:id="@+id/textGreetingSubtitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Бүгін өзіңізді қалай сезініп тұрсыз?"
                android:textColor="#6B7280"
                android:textSize="15sp" />

        <LinearLayout
                android:id="@+id/layoutSearch"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:layout_marginTop="18dp"
                android:background="@drawable/bg_search"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="16dp"
                android:paddingEnd="16dp">

            <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Дәрі немесе дәріхана іздеу"
                    android:textColor="#8E8E99"
                    android:textSize="15sp" />

            <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@android:drawable/ic_menu_search"
                    app:tint="#8E8E99" />
        </LinearLayout>

        <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                app:cardBackgroundColor="#FFFFFF"
                app:cardCornerRadius="26dp"
                app:cardElevation="0dp">

            <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Денсаулық қорытындысы"
                        android:textColor="#111827"
                        android:textSize="19sp"
                        android:textStyle="bold" />

                <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Қазіргі емдеу жоспарыңыз"
                        android:textColor="#6B7280"
                        android:textSize="14sp" />

                <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="18dp"
                        android:orientation="horizontal">

                    <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                        <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Дәрілер"
                                android:textColor="#6B7280"
                                android:textSize="13sp" />

                        <TextView
                                android:id="@+id/textActiveMedicines"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:text="3"
                                android:textColor="#111827"
                                android:textSize="28sp"
                                android:textStyle="bold" />
                    </LinearLayout>

                    <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="2"
                            android:orientation="vertical">

                        <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Келесі қабылдау"
                                android:textColor="#6B7280"
                                android:textSize="13sp" />

                        <TextView
                                android:id="@+id/textNextMedicine"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="6dp"
                                android:text="Парацетамол — 21:00"
                                android:textColor="#111827"
                                android:textSize="16sp"
                                android:textStyle="bold" />
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="18dp"
                        android:orientation="horizontal">

                    <TextView
                            android:id="@+id/textCourseProgress"
                            android:layout_width="0dp"
                            android:layout_height="42dp"
                            android:layout_weight="1"
                            android:background="@drawable/bg_health_chip"
                            android:gravity="center"
                            android:text="5/10 күн"
                            android:textColor="#2563EB"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                    <TextView
                            android:id="@+id/textAdherence"
                            android:layout_width="0dp"
                            android:layout_height="42dp"
                            android:layout_marginStart="10dp"
                            android:layout_weight="1"
                            android:background="@drawable/bg_success_chip"
                            android:gravity="center"
                            android:text="86%"
                            android:textColor="#059669"
                            android:textSize="14sp"
                            android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="Жылдам әрекеттер"
                android:textColor="#111827"
                android:textSize="20sp"
                android:textStyle="bold" />

        <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerQuickActions"
                android:layout_width="match_parent"
                android:layout_height="126dp"
                android:layout_marginTop="12dp"
                android:clipToPadding="false"
                android:overScrollMode="never" />

        <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="AI денсаулық кеңестері"
                android:textColor="#111827"
                android:textSize="20sp"
                android:textStyle="bold" />

        <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerHealthInsights"
                android:layout_width="match_parent"
                android:layout_height="146dp"
                android:layout_marginTop="12dp"
                android:clipToPadding="false"
                android:overScrollMode="never" />

        <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                app:cardBackgroundColor="#FEF3C7"
                app:cardCornerRadius="24dp"
                app:cardElevation="0dp">

            <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="18dp">

                <ImageView
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:background="@drawable/bg_circle_white"
                        android:padding="10dp"
                        android:src="@drawable/ic_sos"
                        app:tint="#DC2626" />

                <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="14dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                    <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="SOS / Жедел ақпарат"
                            android:textColor="#111827"
                            android:textSize="17sp"
                            android:textStyle="bold" />

                    <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="Аллергия, қан тобы, жедел контакт және қазіргі дәрілер"
                            android:textColor="#6B7280"
                            android:textSize="13sp" />
                </LinearLayout>

                <Button
                        android:id="@+id/btnSos"
                        android:layout_width="72dp"
                        android:layout_height="42dp"
                        android:backgroundTint="#DC2626"
                        android:text="SOS"
                        android:textAllCaps="false"
                        android:textColor="#FFFFFF"
                        android:textStyle="bold" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <TextView
                android:id="@+id/titleNews"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="Қазақстандағы денсаулық жаңалықтары"
                android:textColor="#111827"
                android:textSize="20sp"
                android:textStyle="bold" />

        <ProgressBar
                android:id="@+id/progressNews"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp" />

        <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerNews"
                android:layout_width="match_parent"
                android:layout_height="190dp"
                android:layout_marginTop="12dp"
                android:clipToPadding="false"
                android:overScrollMode="never" />

        <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="164dp"
                android:layout_marginTop="18dp"
                app:cardBackgroundColor="#D1FAE5"
                app:cardCornerRadius="24dp"
                app:cardElevation="0dp">

            <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:padding="20dp">

                <TextView
                        android:id="@+id/textDiscount"
                        android:layout_width="190dp"
                        android:layout_height="wrap_content"
                        android:text="Дәріхана бағаларын салыстыру"
                        android:textColor="#111827"
                        android:textSize="24sp"
                        android:textStyle="bold" />

                <TextView
                        android:id="@+id/textDiscountDesc"
                        android:layout_width="190dp"
                        android:layout_height="wrap_content"
                        android:layout_below="@id/textDiscount"
                        android:layout_marginTop="6dp"
                        android:text="Жақын дәріханалардан тиімді баға табыңыз"
                        android:textColor="#4B5563"
                        android:textSize="13sp" />

                <Button
                        android:id="@+id/btnShopNow"
                        android:layout_width="122dp"
                        android:layout_height="44dp"
                        android:layout_alignParentStart="true"
                        android:layout_alignParentBottom="true"
                        android:backgroundTint="#10B981"
                        android:text="Іздеу"
                        android:textAllCaps="false"
                        android:textColor="#FFFFFF"
                        android:textStyle="bold" />

                <TextView
                        android:layout_width="100dp"
                        android:layout_height="100dp"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:gravity="center"
                        android:text="💊"
                        android:textSize="64sp" />
            </RelativeLayout>
        </androidx.cardview.widget.CardView>

        <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="26dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

            <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Себеттегі тауарлар"
                    android:textColor="#111827"
                    android:textSize="20sp"
                    android:textStyle="bold" />

            <TextView
                    android:id="@+id/textSeeAllCart"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Барлығы"
                    android:textColor="#4C4DE6"
                    android:textSize="15sp" />
        </LinearLayout>

        <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerCart"
                android:layout_width="match_parent"
                android:layout_height="220dp"
                android:layout_marginTop="14dp"
                android:clipToPadding="false"
                android:overScrollMode="never" />

        <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

            <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Жеңілдікпен тауарлар"
                    android:textColor="#111827"
                    android:textSize="20sp"
                    android:textStyle="bold" />

            <TextView
                    android:id="@+id/textSeeAllSale"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Барлығы"
                    android:textColor="#4C4DE6"
                    android:textSize="15sp" />
        </LinearLayout>

        <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerSale"
                android:layout_width="match_parent"
                android:layout_height="220dp"
                android:layout_marginTop="14dp"
                android:clipToPadding="false"
                android:overScrollMode="never" />
    </LinearLayout>
</ScrollView>
