<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
        xmlns:android="http://schemas.android.com/apk/res/android"
        xmlns:app="http://schemas.android.com/apk/res-auto"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#F7F9FC">

    <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true"
            android:clipToPadding="false">

        <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingBottom="100dp">

            <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/bg_header_gradient"
                    android:paddingStart="24dp"
                    android:paddingEnd="24dp"
                    android:paddingTop="35dp"
                    android:paddingBottom="32dp">

                <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                    <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">


                        <TextView
                                android:id="@+id/textTreatmentTitle"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:text="Менің емделуім"
                                android:textColor="#FFFFFF"
                                android:textSize="24sp"
                                android:textStyle="bold"
                                android:letterSpacing="-0.02" />

                        <TextView
                                android:id="@+id/textTreatmentSubtitle"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:text="Дәрілерді бақылаңыз"
                                android:textColor="#B2E0DC"
                                android:textSize="12sp" />
                    </LinearLayout>

                    <!-- Add Button -->
                    <androidx.cardview.widget.CardView
                            android:layout_width="52dp"
                            android:layout_height="52dp"
                            app:cardCornerRadius="16dp"
                            app:cardElevation="8dp"
                            app:cardBackgroundColor="#FFFFFF">

                        <ImageButton
                                android:id="@+id/btnAddMedicine"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:background="?attr/selectableItemBackgroundBorderless"
                                android:src="@android:drawable/ic_input_add"
                                android:scaleType="center"
                                app:tint="#0F9B8E" />
                    </androidx.cardview.widget.CardView>
                </LinearLayout>

                <!-- ══════════════════════════════ -->
                <!-- STATS ROW                      -->
                <!-- ══════════════════════════════ -->
                <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="28dp"
                        android:orientation="horizontal">

                    <!-- Stat: Active -->
                    <androidx.cardview.widget.CardView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginEnd="6dp"
                            app:cardCornerRadius="20dp"
                            app:cardElevation="0dp"
                            app:cardBackgroundColor="#19FFFFFF">

                        <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:padding="16dp">

                            <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="💊"
                                    android:textSize="22sp" />

                            <TextView
                                    android:id="@+id/textActiveCount"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="8dp"
                                    android:text="0"
                                    android:textColor="#FFFFFF"
                                    android:textSize="26sp"
                                    android:fontFamily="sans-serif-black" />

                            <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Белсенді дәрі"
                                    android:textColor="#B2E0DC"
                                    android:textSize="12sp"
                                    android:fontFamily="sans-serif-medium" />
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>

                    <!-- Stat: Next Dose -->
                    <androidx.cardview.widget.CardView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="6dp"
                            android:layout_marginEnd="6dp"
                            app:cardCornerRadius="20dp"
                            app:cardElevation="0dp"
                            app:cardBackgroundColor="#19FFFFFF">

                        <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:padding="16dp">

                            <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="⏰"
                                    android:textSize="22sp" />

                            <TextView
                                    android:id="@+id/textNextDose"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="8dp"
                                    android:text="--:--"
                                    android:textColor="#FFFFFF"
                                    android:textSize="26sp"
                                    android:fontFamily="sans-serif-black" />

                            <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Келесі қабылдау"
                                    android:textColor="#B2E0DC"
                                    android:textSize="12sp"
                                    android:fontFamily="sans-serif-medium" />
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>

                    <!-- Stat: Adherence -->
                    <androidx.cardview.widget.CardView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="6dp"
                            app:cardCornerRadius="20dp"
                            app:cardElevation="0dp"
                            app:cardBackgroundColor="#19FFFFFF">

                        <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:padding="16dp">

                            <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="📈"
                                    android:textSize="22sp" />

                            <TextView
                                    android:id="@+id/textAdherence"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="8dp"
                                    android:text="92%"
                                    android:textColor="#FFFFFF"
                                    android:textSize="26sp"
                                    android:fontFamily="sans-serif-black" />

                            <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Тәртіп"
                                    android:textColor="#B2E0DC"
                                    android:textSize="12sp"
                                    android:fontFamily="sans-serif-medium" />
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>
                </LinearLayout>
            </LinearLayout>

            <!-- ══════════════════════════════════════ -->
            <!-- CONTENT SECTION                        -->
            <!-- ══════════════════════════════════════ -->
            <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingStart="20dp"
                    android:paddingEnd="20dp">

                <!-- ── Filter Chips ── -->
                <HorizontalScrollView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:scrollbars="none"
                        android:clipToPadding="false"
                        android:paddingStart="0dp"
                        android:paddingEnd="20dp">

                    <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                        <com.google.android.material.chip.Chip
                                android:id="@+id/chipAll"
                                android:layout_width="wrap_content"
                                android:layout_height="40dp"
                                android:text="Барлығы"
                                android:textSize="12sp"
                                android:checkable="true"
                                android:checked="true"
                                app:chipStrokeWidth="1.5dp"
                                app:checkedIconVisible="false" />

                        <com.google.android.material.chip.Chip
                                android:id="@+id/chipActive"
                                android:layout_width="wrap_content"
                                android:layout_height="40dp"
                                android:layout_marginStart="8dp"
                                android:text="Белсенді"
                                android:textSize="13sp"
                                android:checkable="true"
                                app:chipStrokeWidth="1.5dp"
                                app:checkedIconVisible="false"/>

                        <com.google.android.material.chip.Chip
                                android:id="@+id/chipFinished"
                                android:layout_width="wrap_content"
                                android:layout_height="40dp"
                                android:layout_marginStart="8dp"
                                android:text="Аяқталған"
                                android:textSize="13sp"
                                android:checkable="true"
                                app:chipStrokeWidth="1.5dp"
                                app:checkedIconVisible="false" />

                        <com.google.android.material.chip.Chip
                                android:id="@+id/chipExpired"
                                android:layout_width="wrap_content"
                                android:layout_height="40dp"
                                android:layout_marginStart="8dp"
                                android:text="Мерзімі өткен"
                                android:textSize="13sp"
                                android:checkable="true"
                                app:chipStrokeWidth="1.5dp"
                                app:checkedIconVisible="false"/>
                    </LinearLayout>
                </HorizontalScrollView>

                <!-- ── Current Treatment Section ── -->
                <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                    <!-- Teal accent bar -->
                    <View
                            android:layout_width="3dp"
                            android:layout_height="35dp"
                            android:background="@drawable/bg_accent_bar"
                            android:layout_marginEnd="10dp" />

                    <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                        <TextView
                                android:id="@+id/textCurrentTitle"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Қазір қабылданып жатыр"
                                android:textColor="#1A2B2B"
                                android:textSize="18dp"
                                android:textStyle="bold" />

                        <TextView
                                android:id="@+id/textCurrentCount"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:text="0 белсенді дәрі"
                                android:textColor="#8FA8A6"
                                android:textSize="12sp"/>
                    </LinearLayout>
                </LinearLayout>

                <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/recyclerCurrentTreatment"
                        android:layout_width="match_parent"
                        android:layout_height="200dp"
                        android:layout_marginTop="14dp"
                        android:clipToPadding="false"
                        android:paddingEnd="20dp" />

                <!-- ── All Medicines Section ── -->
                <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="30dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                    <!-- Teal accent bar -->
                    <View
                            android:layout_width="3dp"
                            android:layout_height="35dp"
                            android:background="@drawable/bg_accent_bar"
                            android:layout_marginEnd="10dp" />

                    <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                        <TextView
                                android:id="@+id/textHomeTitle"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Барлық дәрілер"
                                android:textColor="#1A2B2B"
                                android:textSize="18sp"
                                android:textStyle="bold" />

                        <TextView
                                android:id="@+id/textHomeCount"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:text="0 дәрі"
                                android:textColor="#8FA8A6"
                                android:textSize="12sp" />
                    </LinearLayout>
                </LinearLayout>

                <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/recyclerHomeMedicine"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:nestedScrollingEnabled="false" />

            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>